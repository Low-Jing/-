<view class="container"><view class="hero-card"><view class="hero-tag">内容生态与社区板块</view><view class="hero-title">发现</view></view><swiper class="banner-swiper" circular="{{true}}" autoplay="{{true}}" indicator-dots="{{true}}"><block wx:for="{{banners}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><view class="banner-card"><image class="banner-img" src="{{item.img}}" mode="widthFix"></image><view class="banner-text-wrap"><view class="banner-badge">{{item.badge}}</view><view class="banner-title">{{item.title}}</view><view class="banner-subtitle">{{item.subtitle}}</view></view></view></swiper-item></block></swiper><view class="section-card"><view class="section-head"><view class="section-title">为你精选</view><view class="tag-chip">个性化发现</view></view><view class="pick-title">{{editorPick.title||'本周精选'}}</view><view class="tag-list"><block wx:for="{{editorPick.keywords||[]}}" wx:for-item="tag" wx:for-index="index" wx:key="index"><text class="tag">{{tag}}</text></block></view><block wx:for="{{editorPick.reasons||[]}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="reason-line">{{item}}</view></block></view><view class="section-card"><view class="section-title">功能频道</view><view class="channel-grid"><block wx:for="{{channels}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['switchTab',['$0'],[[['channels','',index,'anchor']]]]]]]}}" class="channel-item" bindtap="__e"><view class="channel-icon">{{item.icon}}</view><view class="channel-text">{{item.text}}</view></view></block></view></view><view class="tab-row"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="{{['tab',(activeTab==='all')?'active':'']}}" bindtap="__e">全部</view><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="{{['tab',(activeTab==='challenge')?'active':'']}}" bindtap="__e">挑战</view><view data-event-opts="{{[['tap',[['e2',['$event']]]]]}}" class="{{['tab',(activeTab==='course')?'active':'']}}" bindtap="__e">课程</view><view data-event-opts="{{[['tap',[['e3',['$event']]]]]}}" class="{{['tab',(activeTab==='article')?'active':'']}}" bindtap="__e">知识</view><view data-event-opts="{{[['tap',[['e4',['$event']]]]]}}" class="{{['tab',(activeTab==='community')?'active':'']}}" bindtap="__e">社区</view></view><block wx:if="{{activeTab==='all'||activeTab==='challenge'}}"><view class="section-card"><view class="section-head"><view class="section-title">热门挑战</view><view data-event-opts="{{[['tap',[['loadDiscover',['$event']]]]]}}" class="refresh-link" bindtap="__e">刷新</view></view><block wx:for="{{challenges}}" wx:for-item="item" wx:for-index="__i0__"><view data-event-opts="{{[['tap',[['openDetail',['challenge','$0'],[[['challenges','\'c\'+item.id','c'+item.id]]]]]]]}}" class="challenge-card" bindtap="__e"><view class="challenge-title">{{item.title}}</view><view class="challenge-desc">{{item.description}}</view><view class="challenge-meta"><text>{{item.people_text||item.participant_text}}</text><text>{{item.days+" 天"}}</text></view></view></block><block wx:if="{{!$root.g0}}"><view class="empty-text">暂无挑战数据</view></block></view></block><block wx:if="{{activeTab==='all'||activeTab==='course'}}"><view class="section-card"><view class="section-title">专题课程</view><block wx:for="{{topics}}" wx:for-item="item" wx:for-index="__i1__"><view data-event-opts="{{[['tap',[['openDetail',['course','$0'],[[['topics','\'t\'+item.id','t'+item.id]]]]]]]}}" class="content-card" bindtap="__e"><view class="content-title">{{item.title}}</view><view class="content-desc">{{item.description}}</view></view></block><block wx:if="{{!$root.g1}}"><view class="empty-text">暂无课程数据</view></block></view></block><block wx:if="{{activeTab==='all'||activeTab==='article'}}"><view class="section-card"><view class="section-title">营养知识</view><block wx:for="{{articles}}" wx:for-item="item" wx:for-index="__i2__"><view data-event-opts="{{[['tap',[['openDetail',['article','$0'],[[['articles','\'a\'+item.id','a'+item.id]]]]]]]}}" class="content-card" bindtap="__e"><view class="content-title">{{item.title}}</view><view class="content-desc">{{item.summary}}</view></view></block><block wx:if="{{!$root.g2}}"><view class="empty-text">暂无文章数据</view></block></view></block><block wx:if="{{activeTab==='all'||activeTab==='community'}}"><view class="section-card"><view class="section-title">社区动态</view><block wx:for="{{feeds}}" wx:for-item="item" wx:for-index="__i3__"><view data-event-opts="{{[['tap',[['openDetail',['community','$0'],[[['feeds','\'f\'+item.id','f'+item.id]]]]]]]}}" class="content-card" bindtap="__e"><view class="content-title">{{item.nickname}}</view><view class="content-desc">{{item.content}}</view></view></block><block wx:if="{{!$root.g3}}"><view class="empty-text">暂无社区动态</view></block></view></block><block wx:if="{{detailVisible}}"><view data-event-opts="{{[['tap',[['closeDetail',['$event']]]]]}}" class="popup-mask" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="popup-panel" catchtap="__e"><view class="popup-title">{{detailItem.title||detailItem.nickname}}</view><scroll-view class="popup-scroll" scroll-y="{{true}}"><block wx:if="{{detailType==='challenge'}}"><view><view class="popup-desc">{{detailItem.detail_intro||detailItem.description}}</view><block wx:for="{{detailItem.detail_sections||[]}}" wx:for-item="block" wx:for-index="idx" wx:key="idx"><view class="popup-block"><view class="popup-block-title">{{block.title}}</view><view class="popup-block-desc">{{block.content}}</view></view></block></view></block><block wx:else><block wx:if="{{detailType==='course'}}"><view><view class="popup-desc">{{detailItem.full_content||detailItem.description}}</view><block wx:for="{{detailItem.lesson_points||[]}}" wx:for-item="point" wx:for-index="idx" wx:key="idx"><view class="popup-block-desc">{{"• "+point}}</view></block></view></block><block wx:else><block wx:if="{{detailType==='article'}}"><view><block wx:for="{{detailItem.article_blocks||[]}}" wx:for-item="block" wx:for-index="idx" wx:key="idx"><view class="popup-block-desc">{{block}}</view></block></view></block><block wx:else><view><view class="popup-desc">{{detailItem.content}}</view><block wx:for="{{detailItem.comments_preview||[]}}" wx:for-item="comment" wx:for-index="idx" wx:key="idx"><view class="popup-block-desc">{{comment.nickname+"："+comment.text}}</view></block></view></block></block></block></scroll-view><view class="btn-row"><block wx:if="{{detailType==='challenge'}}"><view data-event-opts="{{[['tap',[['doToggleChallenge',['$0'],['detailItem']]]]]}}" class="btn primary" bindtap="__e">{{detailItem.joined?'取消报名':'立即报名'}}</view></block><block wx:if="{{detailType==='course'}}"><view data-event-opts="{{[['tap',[['doToggleCourse',['$0'],['detailItem']]]]]}}" class="btn primary" bindtap="__e">{{detailItem.favorited?'取消收藏':'收藏课程'}}</view></block><block wx:if="{{detailType==='article'}}"><view data-event-opts="{{[['tap',[['doToggleArticle',['$0'],['detailItem']]]]]}}" class="btn primary" bindtap="__e">{{detailItem.favorited?'取消收藏':'收藏文章'}}</view></block><block wx:if="{{detailType==='community'}}"><view data-event-opts="{{[['tap',[['doTogglePost',['$0'],['detailItem']]]]]}}" class="btn primary" bindtap="__e">{{detailItem.liked?'取消点赞':'点赞动态'}}</view></block><view data-event-opts="{{[['tap',[['closeDetail',['$event']]]]]}}" class="btn light" bindtap="__e">关闭</view></view></view></view></block></view>